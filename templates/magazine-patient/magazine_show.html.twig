{% extends 'base.html.twig' %}

{% block title %}{{ magazine.title }} | MediNest{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('css/magazine.css') }}">
{% endblock %}

{% block body %}

<!-- ================= HERO SECTION ================= -->
<section class="mag-hero">
  <div class="container">
    <div class="mag-hero__content">
      <span class="mag-kicker" data-trans-static>Magazine Sante</span>
      <h1 class="trans-title">{{ magazine.title }}</h1>
      <p class="trans-desc">{{ magazine.description }}</p>
      {% include 'magazine-patient/_translate_selector.html.twig' with {'type': 'magazine', 'id': magazine.id} %}

      <!-- SEARCH -->
      <form action="{{ path('front_magazine_show', {id: magazine.id}) }}"
            method="get"
            class="mag-search-form-small">
        <div class="mag-search-group">
          <input
            type="text"
            name="search"
            placeholder="Filtrer les articles..."
            data-trans-placeholder
            value="{{ searchTerm }}"
            class="mag-search-input">
          <button type="submit" class="mag-search-btn">
            &#128269;
          </button>
        </div>
      </form>

      {% if searchTerm %}
        <div class="mag-search-results">
          <span data-trans-static>Filtre actif :</span> "{{ searchTerm }}"
          <a href="{{ path('front_magazine_show', {id: magazine.id}) }}"
             class="mag-search-clear">
            <span data-trans-static>Annuler</span>
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</section>


<!-- ================= CONTENT SECTION ================= -->
<section class="mag-section">
  <div class="container">

    <!-- ===== HEADER INFO ===== -->
    <div class="mag-detail__header">

      <!-- IMAGE -->
      <div class="mag-detail__media">
        {% if magazine.image %}
          <img src="{{ asset('uploads/' ~ magazine.image) }}"
               alt="{{ magazine.title }}">
        {% else %}
          <div class="mag-card__placeholder" data-trans-static>
            Image non disponible
          </div>
        {% endif %}
      </div>

      <!-- TEXT INFOS -->
      <div class="mag-detail__text">
        <h2 data-trans-static>A propos du magazine</h2>
        <p class="trans-desc">{{ magazine.description }}</p>

        <p style="margin-top:15px;">
          <strong data-trans-static>Date :</strong>
          {{ magazine.dateCreate ? magazine.dateCreate|date('d/m/Y') : '' }}
        </p>

        <p>
          <strong data-trans-static>Statut :</strong>
          <span class="article-tag">{{ magazine.statut }}</span>
        </p>

        <div style="margin-top:18px; display:flex; gap:12px; align-items:center;">
          <button id="generate-mag-summary-btn" class="btn btn-outline-secondary">Resume IA</button>
          <div id="mag-ai-summary-status" style="color:#6b7280; font-size:14px;"></div>
        </div>
        <div id="mag-ai-summary" style="margin-top:12px; background:#f8fafc; padding:12px; border-radius:6px; display:none;"></div>
      </div>
    </div>


    <!-- ================= PDF SECTION ================= -->
    {% if magazine.pdfFile %}
      <div class="mag-pdf-section" style="margin-top:50px;">
        <h2 style="margin-bottom:20px;" data-trans-static>Lire le magazine complet</h2>

        <iframe
          src="{{ asset('uploads/' ~ magazine.pdfFile) }}"
          width="100%"
          height="650px"
          style="
            border:none;
            border-radius:16px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.1);
          ">
        </iframe>
      </div>
    {% endif %}


    <!-- ================= ARTICLES ================= -->
    <div class="mag-articles__header">
      <h2 data-trans-static>Articles recents</h2>
      <span class="mag-count">{{ articles|length }} <span data-trans-static>article(s)</span></span>
    </div>

    <div class="mag-articles">

      {% for article in articles %}
        <article class="article-card" data-id="{{ article.id }}">

          {% if article.image %}
            <div class="article-card__image">
              <img src="{{ asset('uploads/' ~ article.image) }}"
                   alt="{{ article.title }}">
            </div>
          {% endif %}

          <div class="article-card__body">

            <div class="article-card__meta">
              <span>{{ article.auteur }}</span>
              <span>&bull;</span>
              <span>
                {{ article.datePub ? article.datePub|date('d/m/Y') : '' }}
              </span>
            </div>

            <h3>
              <a href="{{ path('front_article_show', {
                    magazineId: magazine.id,
                    id: article.id
                  }) }}"
                 style="text-decoration:none; color:inherit;">
                <span class="trans-title">{{ article.title }}</span>
              </a>
            </h3>

            <p class="trans-resume">
              {% if article.resume %}
                {{ article.resume|slice(0, 160) }}
                {% if article.resume|length > 160 %}...{% endif %}
              {% endif %}
            </p>

            <div class="article-card__footer">
              <span class="article-tag">
                {{ article.statut|default('Article') }}
              </span>
            </div>

          </div>

        </article>

      {% else %}
        <div class="mag-empty">
          <span data-trans-static>Aucun article pour ce magazine.</span>
        </div>
      {% endfor %}

    </div>

  </div>
</section>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% include 'magazine-patient/_translation_assets.html.twig' %}
    <script>
      (function(){
        const btn = document.getElementById('generate-mag-summary-btn');
        const status = document.getElementById('mag-ai-summary-status');
        const out = document.getElementById('mag-ai-summary');
        if (!btn || !status || !out) return;

        btn.addEventListener('click', function(){
          const url = '{{ path('front_magazine_generate_summary', { id: magazine.id }) }}';
          btn.disabled = true;
          status.textContent = 'Generation en cours...';

          fetch(url, { method: 'POST', headers: { 'Accept': 'application/json' } })
            .then(function(res){
              return res.json().then(function(j){
                return { ok: res.ok, status: res.status, json: j };
              });
            })
            .then(function(r){
              if (!r.ok) {
                status.textContent = 'Erreur: ' + (r.json.error || 'Impossible d\'obtenir le resume.');
                btn.disabled = false;
                return;
              }
              out.textContent = r.json.summary || '';
              out.style.display = 'block';
              status.textContent = '';
              btn.disabled = false;
            })
            .catch(function(){
              status.textContent = 'Erreur reseau';
              btn.disabled = false;
            });
        });
      })();
    </script>
{% endblock %}
