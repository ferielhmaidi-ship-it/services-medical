{% extends 'base.html.twig' %}

{% block title %}Détails du Rapport{% endblock %}

{% block body %}
<style>
.page {
    display: flex;
    justify-content: center;
    padding: 80px 0 120px;
    background-color: #f0f2f5;
}

.box {
    background: white;
    padding: 40px;
    border-radius: 12px;
    width: 700px;
    max-width: 95%;
    box-shadow: 0 6px 18px rgba(0,0,0,0.15);
}

h2 {
    text-align: center;
    color: #007BFF;
    margin-bottom: 30px;
}

.row {
    margin-bottom: 12px;
}

.label {
    font-weight: bold;
    color: #333;
}

.value {
    margin-left: 10px;
}

.btn-back {
    margin-top: 30px;
    display: inline-block;
    background: #007BFF;
    color: white;
    padding: 10px 18px;
    border-radius: 6px;
    text-decoration: none;
}
</style>

<div class="page">
    <div class="box">

        <h2>👁 Détails du Rapport</h2>

        <div class="row">
            <span class="label">ID :</span>
            <span class="value">#{{ rapport.idrapport }}</span>
        </div>

        <div class="row">
            <span class="label">Motif :</span>
            <span class="value">{{ rapport.consultationReason }}</span>
        </div>

        <div class="row">
            <span class="label">Diagnostic :</span>
            <span class="value">{{ rapport.diagnosis }}</span>
        </div>

        <div class="row">
            <span class="label">Observations :</span>
            <span class="value">{{ rapport.observations }}</span>
        </div>

        <div class="row">
            <span class="label">Recommandations :</span>
            <span class="value">{{ rapport.recommendations }}</span>
        </div>

        <div class="row">
            <span class="label">Traitements :</span>
            <span class="value">{{ rapport.treatments }}</span>
        </div>

        <div class="row">
            <span class="label">Date :</span>
            <span class="value">
                {{ rapport.createdAt|date('Y-m-d H:i') }}
            </span>
        </div>

        <div class="row">
            <span class="label">Patient :</span>
            <span class="value">
                {{ rapport.idpatient.nom }} {{ rapport.idpatient.prenom }}
            </span>
        </div>

        <div class="row">
            <span class="label">Médecin :</span>
            <span class="value">
                {{ rapport.idmedecin.nom }}
            </span>
        </div>

        <a href="javascript:history.back()" class="btn-back">
            ⬅ Retour
        </a>

    </div>
</div>
{% endblock %}
