{% extends 'base.html.twig' %}

{% block title %}DÃ©tails du Rendez-Vous{% endblock %}

{% block body %}
{% set rendezVous = rapport.rendezVous ?? null %}
<style>
.page {
    display: flex;
    justify-content: center;
    padding: 80px 0 120px;
    background-color: #f0f2f5;
}

.box {
    background: white;
    padding: 40px;
    border-radius: 12px;
    width: 700px;
    max-width: 95%;
    box-shadow: 0 6px 18px rgba(0,0,0,0.15);
}

h2 {
    text-align: center;
    color: #007BFF;
    margin-bottom: 30px;
}

.row {
    margin-bottom: 12px;
}

.label {
    font-weight: bold;
    color: #333;
}

.value {
    margin-left: 10px;
}

.btn-back {
    margin-top: 30px;
    display: inline-block;
    background: #007BFF;
    color: white;
    padding: 10px 18px;
    border-radius: 6px;
    text-decoration: none;
}
</style>

<div class="page">
    <div class="box">

        <h2>ðŸ‘ Détails du Rendez-Vous</h2>

        <div class="row">
            <span class="label">ID :</span>
            <span class="value">{{ rendezVous ? ('#' ~ rendezVous.id) : '-' }}</span>
        </div>

        <div class="row">
            <span class="label">Message :</span>
            <span class="value">{{ rendezVous ? (rendezVous.message ?: '-') : '-' }}</span>
        </div>

        <div class="row">
            <span class="label">Statut :</span>
            <span class="value">{{ rendezVous ? (rendezVous.statut ?: '-') : '-' }}</span>
        </div>

        <div class="row">
            <span class="label">Date du Rendez-Vous :</span>
            <span class="value">
                {{ rendezVous and rendezVous.appointmentDate ? rendezVous.appointmentDate|date('Y-m-d H:i') : '-' }}
            </span>
        </div>

        <div class="row">
            <span class="label">CrÃ©Ã© le :</span>
            <span class="value">
                {{ rendezVous and rendezVous.createdAt ? rendezVous.createdAt|date('Y-m-d H:i') : '-' }}
            </span>
        </div>

        <div class="row">
            <span class="label">Patient :</span>
            <span class="value">
                {{ rendezVous and rendezVous.patient ? (rendezVous.patient.firstName ~ ' ' ~ rendezVous.patient.lastName) : '-' }}
            </span>
        </div>

        <div class="row">
            <span class="label">MÃ©decin :</span>
            <span class="value">
                {{ rendezVous and rendezVous.doctor ? (rendezVous.doctor.firstName ~ ' ' ~ rendezVous.doctor.lastName) : '-' }}
            </span>
        </div>

        <a href="javascript:history.back()" class="btn-back">
            â¬… Retour
        </a>

    </div>
</div>
{% endblock %}

