{% extends 'base.html.twig' %}

{% block body %}

<style>
.page {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    min-height: 100vh;
    padding-top: 80px;
    padding-bottom: 120px; /* ⬅ ESPACE AVANT LE FOOTER */
}

.box {
    background: #ffffff75;
    padding: 35px;
    border-radius: 10px;
    width: 700px;
    max-width: 95%;
    transform: translateY(40px);
}

.box input,
.box textarea,
.box select {
    width: 100%;
    margin-bottom: 12px;
    padding: 10px;
}

button {
    width: 100%;
    padding: 12px;
}
</style>

<div class="page">
    <div class="box">

        {{ form_start(form) }}

        {{ form_row(form.consultation_reason) }}
        {{ form_row(form.diagnosis) }}
        {{ form_row(form.observations) }}
        {{ form_row(form.recommendations) }}
        {{ form_row(form.treatments) }}

        {# remplacer idrendezvous par appointmentDate #}
        {{ form_row(form.rendezVous) }}

        {# remplacer idmedecin par doctor #}
        {{ form_row(form.doctor) }}

        {# remplacer idpatient par patient #}
        {{ form_row(form.patient) }}

        <button>Enregistrer</button>

        {{ form_end(form) }}

        {# datalist pour autocomplete si besoin (optionnel) #}
        <datalist id="rendezvous_list">
        {% for r in rendezvous %}
            <option value="{{ r.appointmentDate|date('Y-m-d H:i') }}">
        {% endfor %}
        </datalist>

        <datalist id="medecin_list">
        {% for m in medecins %}
            <option value="{{ m.getFullName() }}"> {# si Medecin a firstName + lastName #} </option>
        {% endfor %}
        </datalist>

        <datalist id="patient_list">
        {% for p in patients %}
            <option value="{{ p.getFullName() }}">
        {% endfor %}
        </datalist>

        <a href="javascript:history.back()" class="btn-back">
            ⬅ Retour
        </a>

    </div>
</div>

{% endblock %}
