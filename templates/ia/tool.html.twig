{% extends 'base.html.twig' %}

{% block title %}IA - Test{% endblock %}

{% block body %}
<div style="max-width:800px; margin:40px auto; padding:20px; background:#f0f2f5; border-radius:12px;">
    <h1 style="text-align:center; color:#007BFF;">💬 Test IA Ollama</h1>

    <form method="POST" action="{{ path('ia') }}">
        <textarea name="prompt" rows="5" style="width:100%; padding:10px; font-size:16px;" placeholder="Entrez votre question...">{{ prompt }}</textarea>
        <button type="submit" style="margin-top:10px; padding:10px 20px; font-size:16px; background:#007BFF; color:white; border:none; border-radius:8px; cursor:pointer;">Envoyer</button>
    </form>

    {% if answer %}
        <h2 style="margin-top:30px; color:#198754;">Réponse :</h2>
        <pre style="background:#fff; padding:15px; border-radius:8px; box-shadow:0 4px 10px rgba(0,0,0,0.1);">{{ answer }}</pre>
    {% endif %}
</div>
{% endblock %}
