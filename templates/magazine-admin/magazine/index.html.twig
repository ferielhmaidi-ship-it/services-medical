{% extends 'base_admin.html.twig' %}

{% block title %}Gestion des Magazines{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .toolbar-card {
            background: #f4f5fb;
            border: 1px solid #e4e7f2;
            border-radius: 10px;
            padding: 14px;
        }
        .toolbar-card .form-control-sm, .toolbar-card .btn-sm {
            height: 38px;
            font-size: 0.95rem;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-book text-primary"></i> Gestion des Magazines
        </h1>
        <div>
            <a href="{{ path('app_magazine_new') }}" class="btn btn-primary ml-2">
                <i class="fas fa-plus-circle"></i> Nouveau Magazine
            </a>
            <a href="{{ path('app_magazine_index', {'limit': limit|default(10), 'order_by': 'views', 'order_dir': 'desc', 'q': searchQuery|default(''), 'page': 1}) }}" class="btn btn-dark ml-2">
                <i class="fas fa-chart-line"></i> Top Magazines
            </a>
            <span class="badge badge-primary ml-2">
                <i class="fas fa-book"></i> {{ magazines.getTotalItemCount }} Magazine(s)
            </span>
        </div>
    </div>

    <div class="toolbar-card mb-3">
        <form method="get" class="form-inline justify-content-end">
            <label for="q" class="mr-2 mb-0 text-muted">Recherche</label>
            <input id="q"
                   name="q"
                   type="text"
                   class="form-control form-control-sm mr-2"
                   placeholder="Titre, description, statut..."
                   value="{{ searchQuery|default('') }}">
            <label for="limit" class="mr-2 mb-0 text-muted">Par page</label>
            <select id="limit" name="limit" class="form-control form-control-sm mr-2" onchange="this.form.submit()">
                <option value="5" {{ limit == 5 ? 'selected' : '' }}>5</option>
                <option value="10" {{ limit == 10 ? 'selected' : '' }}>10</option>
            </select>
            <label for="order_by" class="mr-2 mb-0 text-muted">Tri</label>
            <select id="order_by" name="order_by" class="form-control form-control-sm mr-2" onchange="this.form.submit()">
                <option value="date" {{ sort == 'date' ? 'selected' : '' }}>Date</option>
                <option value="title" {{ sort == 'title' ? 'selected' : '' }}>Titre</option>
                <option value="views" {{ sort == 'views' ? 'selected' : '' }}>Vues</option>
                <option value="status" {{ sort == 'status' ? 'selected' : '' }}>Statut</option>
            </select>
            <label for="order_dir" class="mr-2 mb-0 text-muted">Ordre</label>
            <select id="order_dir" name="order_dir" class="form-control form-control-sm mr-2" onchange="this.form.submit()">
                <option value="desc" {{ direction == 'desc' ? 'selected' : '' }}>Desc</option>
                <option value="asc" {{ direction == 'asc' ? 'selected' : '' }}>Asc</option>
            </select>
            <input type="hidden" name="page" value="1">
            <button type="submit" class="btn btn-sm btn-primary">Filtrer</button>
            {% if searchQuery is defined and searchQuery is not empty %}
                <a href="{{ path('app_magazine_index', {'limit': limit, 'order_by': sort, 'order_dir': direction, 'page': 1}) }}" class="btn btn-sm btn-outline-secondary ml-2">Reset</a>
            {% endif %}
        </form>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Liste des Magazines</h6>
            <div>
                <a href="{{ path('app_article_index') }}" class="btn btn-info btn-sm">
                    <i class="fas fa-newspaper"></i> Voir les Articles
                </a>
            </div>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="magazineTable">
                    <thead class="thead-dark">
                        <tr>
                            <th>ID</th>
                            <th>Image</th>
                            <th>
                                {% set nextTitleDirection = sort == 'title' and direction == 'asc' ? 'desc' : 'asc' %}
                                <a href="{{ path('app_magazine_index', {'order_by': 'title', 'order_dir': nextTitleDirection, 'limit': limit, 'q': searchQuery|default(''), 'page': 1}) }}" class="text-white">
                                    Titre
                                </a>
                            </th>
                            <th>Description</th>
                            <th>
                                {% set nextDateDirection = sort == 'date' and direction == 'asc' ? 'desc' : 'asc' %}
                                <a href="{{ path('app_magazine_index', {'order_by': 'date', 'order_dir': nextDateDirection, 'limit': limit, 'q': searchQuery|default(''), 'page': 1}) }}" class="text-white">
                                    Date
                                </a>
                            </th>
                            <th>
                                {% set nextStatusDirection = sort == 'status' and direction == 'asc' ? 'desc' : 'asc' %}
                                <a href="{{ path('app_magazine_index', {'order_by': 'status', 'order_dir': nextStatusDirection, 'limit': limit, 'q': searchQuery|default(''), 'page': 1}) }}" class="text-white">
                                    Statut
                                </a>
                            </th>
                            <th>Articles</th>
                            <th>
                                {% set nextViewsDirection = sort == 'views' and direction == 'asc' ? 'desc' : 'asc' %}
                                <a href="{{ path('app_magazine_index', {'order_by': 'views', 'order_dir': nextViewsDirection, 'limit': limit, 'q': searchQuery|default(''), 'page': 1}) }}" class="text-white">
                                    Vues
                                </a>
                            </th>
                            <th>PDF</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        {% for magazine in magazines %}
                            <tr>
                                <td>{{ magazine.id }}</td>
                                <td class="text-center">
                                    {% if magazine.image %}
                                        <img src="{{ asset('uploads/' ~ magazine.image) }}"
                                             alt="{{ magazine.title }}"
                                             class="img-thumbnail"
                                             style="width: 80px; height: 80px; object-fit: cover;"
                                             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                        <div class="bg-light d-flex align-items-center justify-content-center"
                                             style="width: 80px; height: 80px; display:none;">
                                            <i class="fas fa-book fa-2x text-muted"></i>
                                        </div>
                                    {% else %}
                                        <div class="bg-light d-flex align-items-center justify-content-center"
                                             style="width: 80px; height: 80px;">
                                            <i class="fas fa-book fa-2x text-muted"></i>
                                        </div>
                                    {% endif %}
                                </td>
                                <td><strong>{{ magazine.title }}</strong></td>
                                <td>{{ magazine.description|length > 60 ? magazine.description|slice(0, 60) ~ '...' : magazine.description }}</td>
                                <td>{{ magazine.dateCreate|date('d/m/Y') }}</td>
                                <td>
                                    {% if magazine.statut == 'published' %}
                                        <span class="badge badge-success">Publie</span>
                                    {% elseif magazine.statut == 'draft' %}
                                        <span class="badge badge-warning">Brouillon</span>
                                    {% else %}
                                        <span class="badge badge-secondary">Archive</span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    <span class="badge badge-info">{{ articleCounts[magazine.id]|default(0) }}</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge badge-dark">{{ totalViewsByMagazine[magazine.id]|default(0) }}</span>
                                </td>
                                <td class="text-center">
                                    {% if magazine.pdfFile %}
                                        <a href="{{ asset('uploads/' ~ magazine.pdfFile) }}"
                                           target="_blank"
                                           class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-file-pdf"></i>
                                        </a>
                                    {% else %}
                                        <span class="text-muted">Aucun</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <a href="{{ path('app_magazine_show', {'id': magazine.id}) }}" class="btn btn-info btn-sm"><i class="fas fa-eye"></i></a>
                                        <a href="{{ path('app_magazine_edit', {'id': magazine.id}) }}" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
                                        <form method="post" action="{{ path('app_magazine_delete', {'id': magazine.id}) }}" style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ magazine.id) }}">
                                            <button class="btn btn-danger btn-sm" onclick="return confirm('Supprimer ce magazine ?');">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="10" class="text-center">Aucun magazine trouve.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="mt-3 d-flex justify-content-center">
                {{ knp_pagination_render(magazines) }}
            </div>
        </div>
    </div>
{% endblock %}
