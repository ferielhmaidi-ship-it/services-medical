{% extends 'base.html.twig' %}

{% block title %}Dossier Médical{% endblock %}

{% block body %}
<style>
/* ===== PAGE (FAIT DESCENDRE TOUTE LA PAGE) ===== */
.page {
    padding-top: 140px;
    padding-right: 20px;
    padding-left: 20px;
    padding-bottom: 80px;
    background-color: #f0f2f5;
    min-height: 10vh;
}

/* ===== CONTAINER ===== */
.container-box {
    background: #fff;
    padding: 25px;
    border-radius: 12px;
    box-shadow: 0 6px 18px rgba(0,0,0,0.12);
}

/* ===== TITRE ===== */
h1 {
    text-align: center;
    color: #007BFF;
    margin-bottom: 20px;
}

/* ===== TABLE ===== */
.table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
}

.table th,
.table td {
    border: 1px solid #ddd;
    padding: 8px;
    vertical-align: middle;
    text-align: center;
}

.table th {
    background-color: #007BFF;
    color: white;
}

.table tbody tr:hover {
    background-color: #f8f9fa;
}

/* ===== ACTIONS ===== */
.actions a {
    margin: 2px 2px 2px 0;
    display: inline-block;
}

/* ===== BOUTONS ===== */
.btn-sm {
    padding: 4px 8px;
    font-size: 12px;
}
</style>

<div class="page">
    <div class="container-box">
        <h1>📁 Dossier Médical</h1>

        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>ID Document</th>
                        <th>Nom</th>
                        <th>Type</th>
                        <th>Chemin</th>
                        <th>Taille</th>
                        <th>Description</th>
                        <th>Créé le</th>
                        <th>Modifié le</th>
                        <th>Rapports</th>
                        <th>Ordonnances</th>
                        <th>Actions</th>
                        <th>PDF</th> {# ✅ NOUVELLE COLONNE #}
                    </tr>
                </thead>
                <tbody>
                    {% for row in data %}
                        {% set doc = row.document %}
                        <tr>
                            <td>{{ doc.iddocument }}</td>
                            <td>{{ doc.nom }}</td>
                            <td>{{ doc.type }}</td>
                            <td>{{ doc.chemin }}</td>
                            <td>{{ doc.taille }}</td>
                            <td>{{ doc.description }}</td>
                            <td>{{ doc.createdAt ? doc.createdAt|date('d/m/Y H:i') : '-' }}</td>
                            <td>{{ doc.updatedAt ? doc.updatedAt|date('d/m/Y H:i') : '-' }}</td>

                            <td>
                                {% if row.rapports is not empty %}
                                    {% for r in row.rapports %}
                                        #{{ r.idrapport }}
                                        <a class="btn btn-sm btn-primary" href="{{ path('rapport_show', {'idrapport': r.idrapport}) }}">Voir</a>
                                        <a class="btn btn-sm btn-warning" href="{{ path('rapport_mod', {
                                            idrendezvous: r.idrendezvous.idrendezvous,
                                            idpatient: r.idpatient.idpatient,
                                            idmedecin: r.idmedecin.idmedecin,
                                            idrapport: r.idrapport
                                        }) }}">Modifier</a>
                                        <a class="btn btn-sm btn-danger" href="{{ path('rapport_delete', {
                                            idrendezvous: r.idrendezvous.idrendezvous,
                                            idpatient: r.idpatient.idpatient,
                                            idmedecin: r.idmedecin.idmedecin,
                                            idrapport: r.idrapport
                                        }) }}" onclick="return confirm('Supprimer ce rapport ?');">Supprimer</a>
                                        <br>
                                    {% endfor %}
                                {% else %}-{% endif %}
                            </td>

                            <td>
                                {% if row.ordonnances is not empty %}
                                    {% for o in row.ordonnances %}
                                        #{{ o.idordonnance }}
                                        <a class="btn btn-sm btn-primary" href="{{ path('ordonnance_show', {'idordonnance': o.idordonnance}) }}">Voir</a>
                                        <a class="btn btn-sm btn-warning" href="{{ path('ordonnance_mod', {
                                            idrendezvous: o.idrendezvous.idrendezvous,
                                            idpatient: o.idpatient.idpatient,
                                            idmedecin: o.idmedecin.idmedecin,
                                            idordonnance: o.idordonnance
                                        }) }}">Modifier</a>
                                        <a class="btn btn-sm btn-danger" href="{{ path('ordonnance_del', {
                                            idrendezvous: o.idrendezvous.idrendezvous,
                                            idpatient: o.idpatient.idpatient,
                                            idmedecin: o.idmedecin.idmedecin,
                                            idordonnance: o.idordonnance
                                        }) }}" onclick="return confirm('Supprimer cette ordonnance ?');">Supprimer</a>
                                        <br>
                                    {% endfor %}
                                {% else %}-{% endif %}
                            </td>

                            <td>
                                <a class="btn btn-sm btn-success" href="{{ path('document_show', {iddocument: doc.iddocument}) }}">Voir</a>
                                <a class="btn btn-sm btn-primary" href="{{ path('edit_document', {iddocument: doc.iddocument}) }}">Modifier</a>
                                <a class="btn btn-sm btn-danger" href="{{ path('delete_document', {iddocument: doc.iddocument}) }}" onclick="return confirm('Supprimer ce document ?');">Supprimer</a>
                            </td>

                            {# ✅ BOUTON PDF #}
                            <td>
                                <a class="btn btn-sm btn-dark"
                                   href="{{ path('document_pdf', {iddocument: doc.iddocument}) }}">
                                    📄 PDF
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="12" class="text-center">Aucun document trouvé.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
