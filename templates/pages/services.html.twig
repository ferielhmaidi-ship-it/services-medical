{% extends 'base.html.twig' %}

{% block title %}Services - MediNest{% endblock %}
{% block body_class %}services-page{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    :root {
        --primary: #0ea5e9;
        --primary-dark: #0284c7;
        --secondary: #6366f1;
        --dark: #0f172a;
        --gray: #64748b;
        --light: #f8fafc;
        --border: #e2e8f0;
    }

    /* Page Header */
    .page-header {
        background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
        padding: 80px 0 60px;
        border-bottom: 1px solid var(--border);
    }

    .page-title {
        font-size: 42px;
        font-weight: 700;
        color: var(--dark);
        margin-bottom: 12px;
        letter-spacing: -0.02em;
    }

    .page-subtitle {
        font-size: 18px;
        color: var(--gray);
        max-width: 600px;
    }

    /* Breadcrumb */
    .breadcrumb {
        background: transparent;
        padding: 0;
        margin-top: 24px;
    }

    .breadcrumb-item a {
        color: var(--gray);
        text-decoration: none;
    }

    .breadcrumb-item.active {
        color: var(--primary);
        font-weight: 500;
    }

    /* Services Section */
    .services-section {
        padding: 80px 0;
        background: #fff;
    }

    /* Service Card */
    .service-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 40px 32px;
        height: 100%;
        transition: all 0.3s ease;
    }

    .service-card:hover {
        border-color: var(--primary);
        box-shadow: 0 20px 40px -15px rgba(14, 165, 233, 0.15);
        transform: translateY(-4px);
    }

    .service-icon {
        width: 64px;
        height: 64px;
        background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color: var(--primary);
        margin-bottom: 24px;
        transition: all 0.3s ease;
    }

    .service-card:hover .service-icon {
        background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
        color: #fff;
    }

    .service-title {
        font-size: 20px;
        font-weight: 600;
        color: var(--dark);
        margin-bottom: 12px;
    }

    .service-desc {
        font-size: 15px;
        color: var(--gray);
        line-height: 1.6;
        margin-bottom: 24px;
    }

    .service-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--primary);
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        transition: gap 0.3s ease;
    }

    .service-link:hover {
        gap: 12px;
    }

    .service-link i {
        font-size: 12px;
    }
</style>
{% endblock %}

{% block body %}

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <h1 >Our Services</h1>
                <p class="page-subtitle">Comprehensive healthcare services delivered with expertise and compassion</p>
                
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Home</a></li>
                        <li class="breadcrumb-item active">Services</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section class="services-section">
    <div class="container">
        <div class="row g-4">
            {% set services = [
                {icon: 'fa-heartbeat', title: 'Cardiology', desc: 'Advanced cardiac care including diagnostics, interventional procedures, and rehabilitation programs.'},
                {icon: 'fa-brain', title: 'Neurology', desc: 'Comprehensive neurological services from diagnosis to treatment of brain and nervous system disorders.'},
                {icon: 'fa-bone', title: 'Orthopedics', desc: 'Expert musculoskeletal care including joint replacement, sports medicine, and trauma surgery.'},
                {icon: 'fa-baby', title: 'Pediatrics', desc: 'Specialized healthcare for children from newborns to adolescents in a family-centered environment.'},
                {icon: 'fa-ribbon', title: 'Oncology', desc: 'Multidisciplinary cancer care combining cutting-edge treatments with supportive care services.'},
                {icon: 'fa-flask', title: 'Laboratory', desc: 'State-of-the-art diagnostic laboratory offering comprehensive testing and rapid results.'}
            ] %}
            
            {% for service in services %}
            <div class="col-lg-4 col-md-6">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas {{ service.icon }}"></i>
                    </div>
                    <h3 class="service-title">{{ service.title }}</h3>
                    <p class="service-desc">{{ service.desc }}</p>
                    <a href="{{ path('app_service_details') }}" class="service-link">
                        Learn more <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{% endblock %}