{% extends 'base.html.twig' %}

{% block title %}Détails de l'Ordonnance{% endblock %}

{% block body %}
<style>
/* ===== PAGE BACKGROUND ET ESPACEMENT ===== */
.page {
    background: #f0f2f5;
    min-height: 100vh;       /* prend toute la hauteur de l'écran */
    padding: 140px 20px 40px; /* top / sides / bottom */
    display: flex;
    justify-content: center; /* centre horizontalement */
    align-items: flex-start; /* commence depuis le top */
}

/* ===== CARD ===== */
.card {
    background: #fff;
    max-width: 650px;
    width: 100%;
    padding: 30px;
    border-radius: 14px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
}

/* ===== TITRE ===== */
.card h2 {
    text-align: center;
    color: #198754;
    margin-bottom: 25px;
    font-size: 24px;
}

/* ===== ITEMS ===== */
.item {
    margin-bottom: 14px;
    font-size: 15px;
}

.label {
    font-weight: bold;
    color: #555;
}

/* ===== BOUTON RETOUR ===== */
.btn-back {
    display: inline-block;
    margin-top: 30px;
    text-decoration: none;
    background-color: #198754;
    color: #fff;
    padding: 8px 20px;
    border-radius: 8px;
    transition: 0.3s;
}

.btn-back:hover {
    background-color: #146c43;
}
</style>

<div class="page">
    <div class="card">
        <h2>💊 Détails de l’Ordonnance</h2>

        <div class="item">
            <span class="label">ID :</span>
            {{ ordonnance.id }}
        </div>

        <div class="item">
            <span class="label">Médicament :</span>
            {{ ordonnance.medicament }}
        </div>

        <div class="item">
            <span class="label">Posologie :</span>
            {{ ordonnance.posologie }}
        </div>

        <div class="item">
            <span class="label">Instructions :</span>
            {{ ordonnance.instructions }}
        </div>

        <div class="item">
            <span class="label">Notes :</span>
            {{ ordonnance.notes ?: '-' }}
        </div>

        <div class="item">
            <span class="label">Date :</span>
            {{ ordonnance.createdAt|date('d/m/Y H:i') }}
        </div>

        <a href="javascript:history.back()" class="btn-back">
            ⬅ Retour
        </a>
    </div>
</div>
{% endblock %}
