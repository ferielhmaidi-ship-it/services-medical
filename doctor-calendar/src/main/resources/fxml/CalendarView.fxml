<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tabibnet.calendar.controller.CalendarViewController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="40.0">
         <children>
            <VBox>
               <Label styleClass="heading-title" text="Calendrier Hebdomadaire" />
               <Label text="Aperçu des créneaux horaires sur 7 jours. Vous pouvez directement rendre un jour indisponible." style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;" />
            </VBox>

            <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="15.0">
               <children>
                  <!-- Navigation -->
                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <Button styleClass="btn-primary" mnemonicParsing="false" onAction="#previousWeek" text="&lt; Précédent" />
                        <Label fx:id="weekLabel" styleClass="heading-subtitle" text="Semaine du ..." HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" alignment="CENTER"/>
                        <Button styleClass="btn-primary" mnemonicParsing="false" onAction="#nextWeek" text="Suivant &gt;" />
                     </children>
                  </HBox>

                  <!-- 7-Day Grid Container -->
                  <HBox fx:id="weekGrid" spacing="0.0" VBox.vgrow="ALWAYS" />
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
