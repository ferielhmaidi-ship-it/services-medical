<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<BorderPane fx:id="mainBorderPane" prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tabibnet.calendar.controller.MainController">
   <left>
      <VBox prefHeight="700.0" prefWidth="240.0" spacing="10.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="5.0">
                <Label style="-fx-font-family: 'Ubuntu', sans-serif; -fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #1f2f31;" text="Tabib"/>
                <Label style="-fx-font-family: 'Ubuntu', sans-serif; -fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: #099aa7;" text="Net"/>
            </HBox>
            
            <Label text="DOCTOR ESPACE" style="-fx-text-fill: #a2a8a9; -fx-font-size: 11px; -fx-padding: 20 0 5 10; -fx-font-weight: bold;" />
            <Button styleClass="nav-button" mnemonicParsing="false" onAction="#showCalendar" prefWidth="220.0" text="Calendrier" />
            <Button styleClass="nav-button" mnemonicParsing="false" onAction="#showSettings" prefWidth="220.0" text="Disponibilité &amp; Paramètres" />
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="10.0" top="30.0" />
         </padding>
      </VBox>
   </left>
</BorderPane>
